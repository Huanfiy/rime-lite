#!/usr/bin/env python3
# rime-lite userdb 晋升候选分析工具（只读，见 docs/design/architecture.md D-14）
#
# 模型：周期性把 Rime userdb 导出为文本（rime_dict_manager -b / 原生同步产物
#       sync/<installation_id>/pinyin.userdb.txt，格式「拼音<Tab>词<Tab>c=.. d=.. t=..」），
#       本工具读入一份或多份导出，按 D-14 规则机械筛选出晋升候选，
#       供人工审定后再手工写入词库。工具不修改词库与配置文件，
#       输出仅写往 stdout 或 --output 指定路径。
#
# 规则（与 2026-07 首轮晋升 D-14 一致）：
#   1. 丢弃 c<=0 的条目（被删词 / 无效记录）；
#   2. 多份来源按 (词, 拼音) 合并，c 求和；
#   3. 排除：单个 CJK 字、已收录词（对照排除集）、纯 ASCII 且与拼音串
#      （去空格）相同的词（英文原样上屏的学习记录）；
#   4. 合并计数 c_total < --min-count（默认 3）的过滤。
#
# 对照排除集（词级，自动从仓库 rime/ 读取，相对本脚本定位仓库根）：
#   cn_dicts/base、cn_dicts/8105、cn_dicts/embedded、cn_dicts/mydict、
#   custom_phrase.txt、pinyin.dict.yaml
#
# bucket / flag 为机械启发式建议，仅供人工审定参考，不是最终归属：
#   bucket: 含拉丁字母或数字 → custom_phrase；命中领域关键词 → embedded；
#           其余 → mydict
#   flag:   疑似组句残留 → fragment?
#
# 用法:
#   tools/userdb-candidates 导出1.txt [导出2.txt ...]      候选 TSV 打印到 stdout
#   tools/userdb-candidates -o out.tsv 导出.txt            候选写入文件
#   tools/userdb-candidates --min-count 5 导出.txt         调整合并计数阈值
#   tools/userdb-candidates --repo-root <dir> 导出.txt     指定仓库根（复现历史
#                                                          轮次 / 在仓库副本上运行）
#   漏斗统计（各环节计数）始终输出到 stderr。
import argparse
import os
import re
import sys
from collections import defaultdict

HERE = os.path.dirname(os.path.abspath(__file__))
DEFAULT_REPO_ROOT = os.path.dirname(HERE)

# 排除集来源（相对仓库根）
EXCLUDE_DICT_YAMLS = [
    "rime/cn_dicts/base.dict.yaml",
    "rime/cn_dicts/8105.dict.yaml",
    "rime/cn_dicts/embedded.dict.yaml",
    "rime/cn_dicts/mydict.dict.yaml",
    "rime/pinyin.dict.yaml",
]
EXCLUDE_CUSTOM_PHRASE = "rime/custom_phrase.txt"

C_RE = re.compile(r"\bc=(-?\d+)\b")
LATIN_DIGIT_RE = re.compile(r"[A-Za-z0-9]")

